{
  "permissions": {
    "allow": [
      "Bash(cmd.exe /c \"dotnet --version\")",
      "Bash(powershell.exe -Command \"dotnet --version\")",
      "Bash(powershell.exe -Command \"dotnet --version; node --version; npm --version\")",
      "Bash(echo \"$PATH\")",
      "Read(//usr/local/**)",
      "Read(//c/Program Files/**)",
      "Read(//c/Program Files \\(x86\\)/**)",
      "Bash(powershell.exe -Command \"[System.Environment]::GetEnvironmentVariable\\(''Path'',''User''\\)\")",
      "Bash(powershell.exe -Command \"[System.Environment]::GetEnvironmentVariable\\(''Path'',''Machine''\\)\")"
    ]
  }
}
