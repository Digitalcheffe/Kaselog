# Force text treatment for all source and documentation files
# Prevents git or PR checks from treating HTML/SVG content as binary

*.html      text eol=lf
*.htm       text eol=lf
*.svg       text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.json      text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.cs        text eol=lf
*.csproj    text eol=lf
*.sln       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.xml       text eol=lf
*.config    text eol=lf
*.sh        text eol=lf
Dockerfile  text eol=lf

# True binary files — never diff or merge
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
